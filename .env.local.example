# ArxivExplorer — local development environment
# Copy to .env.local and fill in your values.

# API worker base URL (local wrangler dev runs on 8787)
NEXT_PUBLIC_API_BASE=http://localhost:8787

# For server-side fetches (Next.js RSC / ISR)
API_BASE=http://localhost:8787

# Cloudflare credentials for scripts (D1 REST API)
CF_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-account-id
CF_D1_ID=your-d1-database-id

# Admin secret for Vectorize operations
ADMIN_SECRET=your-admin-secret
