{
  "name": "arxiv-explorer",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "pages:build": "opennextjs-cloudflare build",
    "deploy": "npm run pages:build && wrangler deploy --config wrangler.jsonc",
    "deploy:api": "wrangler deploy --config wrangler.api.toml",
    "deploy:ingest": "wrangler deploy --config wrangler.ingest.toml",
    "db:migrate": "wrangler d1 execute arxiv-explorer --file=migrations/schema.sql",
    "db:migrate:remote": "wrangler d1 execute arxiv-explorer --remote --file=migrations/schema.sql",
    "ingest": "npx tsx scripts/bulk-ingest.ts",
    "upload-embeddings": "npx tsx scripts/upload-embeddings.ts",
    "db:export": "wrangler d1 export arxiv-explorer --local --output backup.sql",
    "db:push": "wrangler d1 execute arxiv-explorer --remote --file backup.sql"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.10",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.184.1",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5.8.2",
    "wrangler": "^4.86.0",
    "xml2js": "^0.6.2"
  }
}
