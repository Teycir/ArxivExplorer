{
  "name": "arxiv-explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "pages:build": "opennextjs-cloudflare build",
    "deploy": "npm run pages:build && wrangler deploy --config wrangler.jsonc",
    "deploy:api": "wrangler deploy --config wrangler.api.toml",
    "deploy:ingest": "wrangler deploy --config wrangler.ingest.toml",
    "db:migrate": "wrangler d1 execute arxiv-explorer --file=migrations/0001_schema.sql",
    "db:migrate:remote": "wrangler d1 execute arxiv-explorer --remote --file=migrations/0001_schema.sql"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.10",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "wrangler": "^4.86.0"
  }
}
